{
  "name": "@varcore/policy",
  "version": "1.2.0",
  "description": "NonSudo deterministic YAML policy engine",
  "license": "Apache-2.0",
  "keywords": [
    "nonsudo",
    "policy",
    "yaml",
    "governance",
    "agent",
    "ai",
    "safety",
    "firewall"
  ],
  "homepage": "https://nonsudo.com",
  "bugs": {
    "url": "https://github.com/varcore-standards/varcore/issues"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/varcore-standards/varcore",
    "directory": "packages/policy"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
